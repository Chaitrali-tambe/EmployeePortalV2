@{
}

@model EmployeePortal.Models.AddDesignationViewModel;

<h1>Add Designation</h1>

<form asp-action="AddDesignation" method="post">
    @Html.AntiForgeryToken()
    <div class="rounded-1 bg-body-secondary">
        <div class="mt-3">
            <label class="form-label">Designation</label>
            <input class="form-control w-50" asp-for="desnName" />
        </div>
        <div class="mt-2">
            <label class="form-label">Department </label>
            <select asp-for="department" class="form-control w-50"
                    asp-items="ViewBag.DepartmentList">
                <option value="">-- Select Designation --</option>
            </select>
        </div>

        <div class="mt-3 d-flex">
            <button class="btn btn-primary" style="width:80px" type="submit">Submit</button>
            <button class="btn btn-danger ms-2" onclick="confirmClear()" style="width:80px">Clear</button>
        </div>
    </div>
</form>