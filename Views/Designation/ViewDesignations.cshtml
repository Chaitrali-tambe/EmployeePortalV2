@{
}

@model IEnumerable<EmployeePortal.Models.DesignationViewModel> ;

<div class="d-flex align-items-center justify-content-between">
    <h1 class="mb-3">Designations</h1>
    <a class="btn darkTeal-bg w-fit-content" asp-controller="Designation" asp-action="AddDesignation">Add Designation</a>
</div>

@foreach (var departmentGroup in ViewBag.GroupedData)
{
    <h3 class="darkTeal">@departmentGroup.deparmentName</h3>
    <ul>
        @foreach (var des in departmentGroup.designation)
        {
            <li class="card  mx-lg-3 my-lg-3 my-sm-2 my-2 bg-success bg-gradient bg-opacity-25 pe-none darkTeal-border p-2 w-50 my-2">@des.desnName</li>
        }
    </ul>
}