@{
}

@model List<EmployeePortal.Models.EmployeeViewModel>;


<div class="d-flex align-items-center justify-content-between">
    <h1 class="mb-3">Employee List</h1>
    <a asp-controller="Employee" asp-action="Add" class="btn darkTeal-bg w-fit-content">Add Employee</a>
</div>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>
                ID
            </th>
            <th>
                NAME
            </th>
            <th>
                AGE
            </th>
            <th>
                CITY
            </th>
            <th>
                SALARY
            </th>
            <th>
                DOB
            </th>
            <th>
                DESIGNATION
            </th>
            <th>
                BRANCH
            </th>
            <th>
                BRANCH
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach(var employee in Model){
            <tr>
                <td>@employee.Id</td>
                <td>@employee.Name</td>
                <td>@employee.Age</td>
                <td>@employee.City</td>
                <td>@employee.salary</td>
                <td>@employee.DOB</td>
                <td>@employee.desnName</td>
                <td>@employee.Branch</td>
                <td>@employee.Dept</td>
                <td><a asp-controller="Employee" asp-action="Edit" asp-route-id="@employee.Id">Edit</a></td>
            </tr>
        }
    </tbody>
</table>