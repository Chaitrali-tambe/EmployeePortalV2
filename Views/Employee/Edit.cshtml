    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model EmployeePortal.Models.Entities.Employee;


<h1>Edit Employee</h1>
@if (Model is null)
{
    <p>No Student was found with this Id</p>
}
else
{
    <form asp-action="Edit" method="post">

        <div class="rounded-1 bg-body-secondary">
            <div class="mt-3">
                <label class="form-label">Id</label>
                <input class="form-control w-50" asp-for="Id" readonly />
            </div>
            <div class="mt-3">
                <label class="form-label">Name</label>
                <input class="form-control w-50" asp-for="Name" />
            </div>

            <div class="mt-2">
                <label class="form-label">Age</label>
                <input maxlength="3" type="number" class="form-control w-50" asp-for="Age" readonly />
            </div>

            <div class="mt-2">
                <label class="form-label">City</label>
                <input class="form-control w-50" asp-for="City" />
            </div>

            <div class="mt-2">
                <label class="form-label">Salary</label>
                <input type="number" maxlength="12" class="form-control w-50" asp-for="salary" />
            </div>

            <div class="mt-2">
                <label class="form-label">DOB</label>
                <input type="date" class="form-control w-50" asp-for="DOB" />
            </div>

            <div class="mt-2">
                <label class="form-label">Designation</label>
                <select type="date" class="form-control w-50" asp-for="desnName" asp-items="@(new SelectList(ViewBag.Designation, "Value", "Text"))" id="ddlDesgn">
                    <option value="">-- Select Designation --</option>
                </select>
            </div>

            <div class="mt-2">
                <label class="form-label">Branch</label>
                <select type="date" class="form-control w-50" asp-for="Branch" asp-items="ViewBag.Branches">
                    <option value="">-- Select Branch --</option>
                </select>
            </div>

            <div class="mt-2">
                <label class="form-label">Department</label>
                <select type="date" class="form-control w-50" asp-for="DeptId" asp-items="@(new SelectList(ViewBag.Department, "Value", "Text"))" id="ddlDept">
                    <option value="">-- Select Department --</option>
                </select>
            </div>

            <div class="mt-3 d-flex">
                <button class="btn btn-primary" style="width:80px" onclick="">Submit</button>
                <button class="btn btn-danger ms-2" asp-action="Delete" asp-controller="Employee">Delete</button>
            </div>
        </div>

    </form>

}

@section Scripts {
    <script src="jquery-3.7.1.min.js"></script>
    <script>
        $(document).ready(function() {
                    $('#ddlDesgn').change(function (){
                        var seldesgnName = $(this).val();
                        console.log("Selected Designation: " + seldesgnName);
                        if(seldesgnName){
                            $.ajax({
                            url: '@Url.Action("GetDeptByDesgn", "Employee")', // Update with your actual Controller name
                            type: 'GET',
                            data: { desgnName: seldesgnName },
                            success: function (response) {
                                if (response.deptId !== 0) {
                                    // This line forces the Department dropdown to change
                                    // to the ID returned from the server
                                    $('#ddlDept').val(response.deptId);
                                }
                            },
                            error: function (xhr) {
                                console.log("Error logic: " + xhr.statusText);
                            }
                        });
                        }
                    });
                });
    </script>
}


