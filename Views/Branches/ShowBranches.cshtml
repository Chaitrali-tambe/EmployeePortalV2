@{
}

@model List< EmployeePortal.Models.Entities.Branches>;

<div class="d-flex align-items-center justify-content-between">
    <h1 class="mb-3">Branches</h1>
    <a asp-controller="Branches" asp-action="AddBranches" class="btn darkTeal-bg w-fit-content">Add Branches</a>
</div>


<table class="table table-bordered">
    <thead>
        <tr>
            <td>Branch Code</td>
            <td>Branch Name</td>
            <td>City Code</td>
            <td>City</td>
        </tr>
    </thead>
    <tbody>

        @foreach(var br in Model)
        {
            <tr>
                <td>@br.BrCode</td>
                <td>@br.BrName</td>
                <td>@br.CityCode</td>
                <td>@br.City</td>
            </tr>
        }
        
    </tbody>
</table>